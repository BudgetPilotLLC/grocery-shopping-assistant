# Grocery Shopping Assistant
GROCERY_ASSISTANT_TOKEN=choose-a-long-random-token
GROCERY_LIST_PATH=/app/data/grocery-list.txt

# Amazon.com live-price provider.
# Use official API/provider credentials here, not your Amazon shopping username/password.
# The exact variables may change once we choose Creators API, affiliate API, or a data provider.
AMAZON_PROVIDER=disabled
AMAZON_MARKETPLACE=US
AMAZON_ASSOCIATE_TAG=
AMAZON_ACCESS_KEY_ID=
AMAZON_SECRET_ACCESS_KEY=
AMAZON_CREATORS_API_TOKEN=

# Amazon Fresh is location-sensitive and does not have a broad public consumer price API.
# Keep disabled until we choose a credentialed provider or explicit assisted capture workflow.
AMAZON_FRESH_PROVIDER=disabled
AMAZON_FRESH_ZIP=

