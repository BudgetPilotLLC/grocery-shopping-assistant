:root {
  --ink: #17211b;
  --muted: #5d6b63;
  --surface: #ffffff;
  --paper: #f5f7f2;
  --line: #dce4da;
  --green: #2f6b3f;
  --green-dark: #173c27;
  --teal: #167c80;
  --blue: #315f86;
  --amber: #b56b21;
  --shadow: 0 18px 46px rgba(23, 33, 27, 0.12);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  color: var(--ink);
  background: var(--paper);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

a {
  color: inherit;
}

.site-nav {
  position: fixed;
  inset: 0 0 auto;
  z-index: 10;
  min-height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 16px clamp(18px, 5vw, 72px);
  color: white;
}

.site-nav.plain {
  position: sticky;
  color: var(--ink);
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(14px);
}

.brand,
nav,
.hero-actions,
.footer-links {
  display: flex;
  align-items: center;
}

.brand {
  gap: 10px;
  text-decoration: none;
  font-weight: 800;
}

.brand-mark {
  width: 34px;
  height: 34px;
  display: grid;
  place-items: center;
  border-radius: 8px;
  background: var(--green);
  color: white;
  box-shadow: 0 8px 20px rgba(23, 33, 27, 0.18);
}

nav {
  gap: clamp(12px, 3vw, 26px);
  font-size: 0.94rem;
}

nav a,
.footer-links a {
  text-decoration: none;
  color: inherit;
}

nav a:hover,
.footer-links a:hover {
  text-decoration: underline;
}

.hero {
  min-height: 82vh;
  display: flex;
  align-items: center;
  padding: 110px clamp(18px, 5vw, 72px) 70px;
  background-image:
    linear-gradient(90deg, rgba(18, 37, 26, 0.88) 0%, rgba(18, 37, 26, 0.68) 42%, rgba(18, 37, 26, 0.18) 100%),
    url("assets/app-preview.png");
  background-size: cover;
  background-position: center;
  color: white;
}

.hero-content {
  width: min(720px, 100%);
}

.eyebrow {
  margin: 0 0 14px;
  color: var(--amber);
  font-size: 0.78rem;
  font-weight: 850;
  letter-spacing: 0;
  text-transform: uppercase;
}

.hero .eyebrow {
  color: #f0c07e;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 20px;
  max-width: 700px;
  font-size: clamp(3rem, 8vw, 6.6rem);
  line-height: 0.92;
  letter-spacing: 0;
}

h2 {
  margin-bottom: 18px;
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1.02;
  letter-spacing: 0;
}

h3 {
  margin-bottom: 8px;
  font-size: 1.08rem;
}

.hero-copy {
  max-width: 620px;
  color: rgba(255, 255, 255, 0.9);
  font-size: clamp(1.08rem, 2vw, 1.35rem);
  line-height: 1.5;
}

.hero-actions {
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}

.button {
  min-height: 46px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  padding: 0 18px;
  text-decoration: none;
  font-weight: 800;
}

.button.primary {
  color: var(--green-dark);
  background: white;
}

.button.secondary {
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.64);
}

.band {
  background: var(--surface);
  border-bottom: 1px solid var(--line);
}

.section,
.intro {
  padding: clamp(54px, 8vw, 108px) clamp(18px, 5vw, 72px);
}

.section-inner {
  width: min(1120px, 100%);
  margin: 0 auto;
}

.lead {
  margin-bottom: 0;
  font-size: clamp(1.35rem, 3vw, 2rem);
  line-height: 1.35;
}

.two-column,
.split {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: clamp(32px, 6vw, 72px);
  align-items: start;
}

.feature-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.feature-list article,
.data-panel,
.callout {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface);
  box-shadow: var(--shadow);
}

.feature-list article {
  padding: 22px;
}

.feature-list p,
.data-panel li,
.section p,
.document p {
  color: var(--muted);
  line-height: 1.6;
}

.contrast {
  color: white;
  background: var(--green-dark);
}

.contrast .eyebrow {
  color: #f0c07e;
}

.contrast p {
  color: rgba(255, 255, 255, 0.82);
}

.data-panel {
  padding: 28px;
  color: var(--ink);
}

.data-panel ul {
  margin: 18px 0 0;
  padding-left: 22px;
}

.data-panel li + li {
  margin-top: 10px;
}

.callout {
  padding: clamp(28px, 5vw, 48px);
}

.callout h2 {
  max-width: 760px;
}

.callout p {
  max-width: 780px;
  margin-bottom: 0;
}

footer {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  padding: 30px clamp(18px, 5vw, 72px);
  color: white;
  background: #121913;
}

footer p {
  max-width: 680px;
  margin: 8px 0 0;
  color: rgba(255, 255, 255, 0.74);
  font-size: 0.92rem;
}

.footer-links {
  gap: 18px;
  align-self: start;
}

.plain-page {
  background: var(--surface);
}

.document {
  width: min(860px, calc(100% - 36px));
  margin: 0 auto;
  padding: clamp(54px, 8vw, 90px) 0;
}

.document h1 {
  color: var(--ink);
  font-size: clamp(2.8rem, 7vw, 4.8rem);
}

.document h2 {
  margin: 38px 0 10px;
  font-size: clamp(1.35rem, 3vw, 2rem);
}

.updated {
  color: var(--muted);
}

@media (max-width: 820px) {
  .site-nav {
    position: absolute;
    align-items: flex-start;
    flex-direction: column;
  }

  .site-nav.plain {
    position: sticky;
  }

  nav {
    width: 100%;
    justify-content: space-between;
  }

  .hero {
    min-height: 78vh;
    align-items: flex-end;
    background-image:
      linear-gradient(180deg, rgba(18, 37, 26, 0.32) 0%, rgba(18, 37, 26, 0.9) 72%),
      url("assets/app-preview.png");
  }

  .two-column,
  .split,
  .feature-list {
    grid-template-columns: 1fr;
  }

  footer {
    flex-direction: column;
  }
}

